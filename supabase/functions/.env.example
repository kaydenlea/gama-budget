# Private function environment for local Supabase Edge Function work.
# Do not commit real secrets. Copy into your local Supabase function env setup.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SB_JWT_ISSUER=

# Plaid server-side credentials.
PLAID_CLIENT_ID=your-plaid-client-id
